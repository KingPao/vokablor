{
  "name": "@vokablor/backend",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch src/api/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/api/app.js",
    "migrate": "tsx src/migrations/run.ts up",
    "migrate:down": "tsx src/migrations/run.ts down",
    "seed:rss": "tsx src/scripts/seed-rss-sources.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "hono": "^4.6.14",
    "kysely": "^0.29.2",
    "mysql2": "^3.11.5",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^5.9.3",
    "@hono/node-server": "^1.13.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
