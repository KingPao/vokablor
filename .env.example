# --- MySQL ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=vokablor
MYSQL_USER=vokablor
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-too

# --- Backend server ---
PORT=3000
NODE_ENV=development

# --- Sessions ---
# 32+ byte random secret used to sign session cookies (session ID stored server-side; see research.md #4)
SESSION_SECRET=change-me-to-a-long-random-string
# Leave unset (defaults to true) behind the HTTPS reverse proxy. Only set to "false" for local
# HTTP-only dev/E2E — a Secure cookie is never stored by browsers that enforce the cookie spec
# strictly over plain HTTP (WebKit/Safari does, even for localhost; Chromium is lenient there).
COOKIE_SECURE=true

# --- Secrets at rest ---
# 32-byte (base64) key used to encrypt AIProviderConfig.api_key_encrypted (research.md #3/#5)
API_KEY_ENCRYPTION_KEY=change-me-to-a-base64-32-byte-key

# --- AI providers ---
# Shared free-tier fallback used when a learner has not configured their own provider (research.md #6)
NVIDIA_FREE_API_KEY=
NVIDIA_FREE_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_FREE_MODEL=meta/llama-3.1-8b-instruct
# Per-learner request budget on the shared free-tier path (research.md #6)
NVIDIA_FREE_RATE_LIMIT_PER_DAY=50

# --- Content sourcing ---
# Comma-separated RSS feed URLs seeded per language (research.md #7); see src/scripts/seed-rss-sources.ts
RSS_FEEDS_FR=
RSS_FEEDS_ES=
RSS_FEEDS_DE=
